function sideScroll(button, direction) {
    const wrapper = button.parentElement;
    const slider = wrapper.querySelector('.products-slider');
    const scrollAmount = 300; 

    if (direction === 'left') {
        slider.scrollBy({
            left: -scrollAmount,
            behavior: 'smooth' 
        });
    } else if (direction === 'right') {
        slider.scrollBy({
            left: scrollAmount,
            behavior: 'smooth'
        });
    }
}
